                "body": {
                  "mode": "raw",
                  "raw": "[\n  {\n    \"metrics\": [\n      {\n        \"name\": \"<string>\",\n        \"type\": \"count\",\n        \"value\": \"<number>\",\n        \"timestamp\": \"<integer>\",\n        \"interval.ms\": \"<integer>\",\n        \"attributes\": {\n          \"qui_4c8\": \"<string>\",\n          \"eiusmod_543\": \"<string>\"\n        }\n      },\n      {\n        \"name\": \"<string>\",\n        \"type\": \"gauge\",\n        \"value\": \"<number>\",\n        \"timestamp\": \"<integer>\",\n        \"interval.ms\": \"<integer>\",\n        \"attributes\": {\n          \"in_c7\": \"<string>\",\n          \"proident4\": \"<string>\"\n        }\n      }\n    ],\n    \"common\": {\n      \"timestamp\": \"<integer>\",\n      \"interval.ms\": \"<integer>\",\n      \"attributes\": {\n        \"commodo_c8\": \"<string>\"\n      }\n    }\n  },\n  {\n    \"metrics\": [\n      {\n        \"name\": \"<string>\",\n        \"type\": \"summary\",\n        \"value\": \"<number>\",\n        \"timestamp\": \"<integer>\",\n        \"interval.ms\": \"<integer>\",\n        \"attributes\": {\n          \"sintb5\": \"<string>\",\n          \"irure1a\": \"<string>\",\n          \"laboris_90\": \"<string>\"\n        }\n      },\n      {\n        \"name\": \"<string>\",\n        \"type\": \"count\",\n        \"value\": \"<number>\",\n        \"timestamp\": \"<integer>\",\n        \"interval.ms\": \"<integer>\",\n        \"attributes\": {\n          \"qui_f\": \"<string>\",\n          \"aute_1c2\": \"<string>\"\n        }\n      }\n    ],\n    \"common\": {\n      \"timestamp\": \"<integer>\",\n      \"interval.ms\": \"<integer>\",\n      \"attributes\": {\n        \"Excepteur_f50\": \"<string>\"\n      }\n    }\n  }\n]",
