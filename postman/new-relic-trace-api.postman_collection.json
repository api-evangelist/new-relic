{
  "info": {
    "_postman_id": "d43971bf-0f51-4796-96b8-cba89c480803",
    "name": "New Relic Trace API",
    "description": "The New Relic Trace API allows distributed tracing data to be sent directly to New Relic in either New Relic format or Zipkin JSON v2 format. It is used by Telemetry SDKs, open source integrations, and custom tracing implementations that need to report span data without a full APM agent. Traces appear in the New Relic Distributed Tracing UI after processing.\n\nContact Support:\n Name: New Relic Support",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T13:03:00.000Z",
    "updatedAt": "2026-06-05T13:03:01.000Z",
    "lastUpdatedBy": "35240",
    "uid": "35240-d43971bf-0f51-4796-96b8-cba89c480803"
  },
