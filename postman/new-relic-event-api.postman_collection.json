                          "mode": "raw",
                          "raw": "[\n  {\n    \"eventType\": \"<string>\",\n    \"timestamp\": \"<integer>\"\n  },\n  {\n    \"eventType\": \"<string>\",\n    \"timestamp\": \"<integer>\"\n  }\n]",
