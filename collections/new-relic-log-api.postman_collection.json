        {
          "id": "5c7876b2-3d7d-48e7-a226-77f7cc57bed9",
          "name": "New Relic Send Log Data",
          "request": {
            "name": "New Relic Send Log Data",
            "description": {
              "content": "Sends one or more log records to the New Relic Log API. Accepts a JSON array of log data objects, each containing a logs array and optional common attributes. Payloads must be gzip-compressed. A single request may not exceed 1 MB compressed or 10,000 log entries.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "log",
                "v1"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "disabled": false,
                "description": "(Required) Compression encoding. Gzip is required.",
                "key": "Content-Encoding",
                "value": "<string>"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"logs\": [\n      {\n        \"timestamp\": \"<integer>\",\n        \"message\": \"<string>\",\n        \"level\": \"<string>\",\n        \"logtype\": \"<string>\",\n        \"attributes\": {\n          \"key_0\": \"<string>\",\n          \"key_1\": \"<string>\"\n        }\n      },\n      {\n        \"timestamp\": \"<integer>\",\n        \"message\": \"<string>\",\n        \"level\": \"<string>\",\n        \"logtype\": \"<string>\",\n        \"attributes\": {\n          \"key_0\": \"<string>\"\n        }\n      }\n    ],\n    \"common\": {\n      \"timestamp\": \"<integer>\",\n      \"attributes\": {\n        \"key_0\": \"<string>\"\n      }\n    }\n  },\n  {\n    \"logs\": [\n      {\n        \"timestamp\": \"<integer>\",\n        \"message\": \"<string>\",\n        \"level\": \"<string>\",\n        \"logtype\": \"<string>\",\n        \"attributes\": {\n          \"key_0\": \"<string>\",\n          \"key_1\": \"<string>\"\n        },\n        \"key_0\": {},\n        \"key_1\": {}\n      },\n      {\n        \"timestamp\": \"<integer>\",\n        \"message\": \"<string>\",\n        \"level\": \"<string>\",\n        \"logtype\": \"<string>\",\n        \"attributes\": {\n          \"key_0\": \"<string>\"\n        },\n        \"key_0\": {},\n        \"key_1\": {}\n      }\n    ],\n    \"common\": {\n      \"timestamp\": \"<integer>\",\n      \"attributes\": {\n        \"key_0\": \"<string>\",\n        \"key_1\": \"<string>\"\n      }\n    }\n  }\n]",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [
            {
              "id": "c00a5879-d857-4486-911d-02894f2edd5c",
              "name": "Accepted. Log data was received and queued for processing.",
              "originalRequest": {
                "url": {
                  "path": [
                    "log",
                    "v1"
                  ],
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "query": [],
                  "variable": []
                },
                "header": [
                  {
                    "description": {
                      "content": "Added as a part of security scheme: apikey",
                      "type": "text/plain"
                    },
                    "key": "Api-Key",
                    "value": "<API Key>"
                  },
                  {
                    "disabled": false,
                    "description": "(Required) Compression encoding. Gzip is required.",
                    "key": "Content-Encoding",
                    "value": "gzip"
                  },
                  {
                    "disabled": false,
                    "description": "(Required) ",
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Accept",
                    "value": "application/json"
                  }
                ],
                "method": "POST",
                "body": {
                  "mode": "raw",
                  "raw": "[\n  {\n    \"common\": {\n      \"attributes\": {\n        \"logtype\": \"nginx\",\n        \"service.name\": \"myService\",\n        \"host.name\": \"web01\"\n      }\n    },\n    \"logs\": [\n      {\n        \"timestamp\": 1645564509000,\n        \"message\": \"127.0.0.1 - - [01/Jan/2022] \\\"GET /api/health HTTP/1.1\\\" 200 24\",\n        \"level\": \"INFO\"\n      },\n      {\n        \"timestamp\": 1645564510000,\n        \"message\": \"127.0.0.1 - - [01/Jan/2022] \\\"POST /api/orders HTTP/1.1\\\" 500 0\",\n        \"level\": \"ERROR\"\n      }\n    ]\n  }\n]",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                }
              },
              "status": "Accepted",
              "code": 202,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"requestId\": \"500123\"\n}",
