  "info": {
    "_postman_id": "1f1cf3bd-f34b-40db-a4a7-6668122faa33",
    "name": "New Relic Trace API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The New Relic Trace API allows distributed tracing data to be sent directly to New Relic in either New Relic format or Zipkin JSON v2 format. It is used by Telemetry SDKs, open source integrations, and custom tracing implementations that need to report span data without a full APM agent. Traces appear in the New Relic Distributed Tracing UI after processing.\n\nContact Support:\n Name: New Relic Support",
      "type": "text/plain"
    }
  }
