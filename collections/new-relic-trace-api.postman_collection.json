          "id": "c0eee40b-c376-47d6-b019-ae2ba24f5eda",
          "name": "New Relic Send Trace Spans",
          "request": {
            "name": "New Relic Send Trace Spans",
            "description": {
              "content": "Sends distributed trace spans to New Relic. Supports New Relic format (Content-Type application/json with Data-Format newrelic) and Zipkin JSON v2 format (Data-Format zipkin). Payloads can be gzip-compressed. A single request supports up to 10,000 spans and must not exceed 1 MB compressed.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "trace",
                "v1"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "disabled": false,
                "description": "(Required) The format of the trace data in the request body",
                "key": "Data-Format",
                "value": "<string>"
              },
              {
                "disabled": false,
                "description": "Version of the data format. Use 1 for newrelic format.",
                "key": "Data-Format-Version",
                "value": "<string>"
              },
              {
                "disabled": false,
                "description": "Use gzip for compressed payloads",
                "key": "Content-Encoding",
                "value": "<string>"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
