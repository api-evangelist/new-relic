atusCode\": \"<integer>\",\n          \"key_0\": {\n            \"value\": \"<Error: Too many levels of nesting to fake this schema>\"\n          },\n          \"key_1\": {\n            \"value\": \"<Error: Too many levels of nesting to fake this schema>\"\n          }\n        }\n      },\n      {\n        \"id\": \"<string>\",\n        \"trace.id\": \"<string>\",\n        \"timestamp\": \"<integer>\",\n        \"attributes\": {\n          \"name\": \"<string>\",\n          \"parent.id\": \"<string>\",\n          \"duration.ms\": \"<number>\",\n          \"service.name\": \"<string>\",\n          \"error\": \"<boolean>\",\n          \"db.statement\": \"<string>\",\n          \"http.url\": \"<string>\",\n          \"http.method\": \"<string>\",\n          \"http.statusCode\": \"<integer>\"\n        }\n      }\n    ],\n    \"common\": {\n      \"attributes\": {\n        \"key_0\": \"<string>\",\n        \"key_1\": \"<string>\"\n      }\n    }\n  }\n]",
