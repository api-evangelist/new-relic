          "name": "New Relic Send Metric Data",
          "request": {
            "name": "New Relic Send Metric Data",
            "description": {
              "content": "Sends an array of metric data points to the New Relic Metric API. The request body must be a JSON array of metric data objects, each containing a metrics array and optional common attributes. Payloads should be gzip-compressed for best performance. The API supports count, gauge, and summary metric types.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "metric",
                "v1"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "disabled": false,
                "description": "(Required) New Relic License Key or Ingest API Key with Insert permissions",
                "key": "Api-Key",
                "value": "<string>"
              },
              {
                "disabled": false,
                "description": "Compression encoding. Use gzip for compressed payloads.",
                "key": "Content-Encoding",
                "value": "<string>"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
